# API 提供商选择（系统自动加载对应的客户端）
api_provider: "openai"  # 可选: openai, claude, 或其他已实现的客户端

# OpenAI API 配置
# 提示：所有 API 配置都在这里，方便切换不同的 API 提供商
openai:
  api_key: "your-api-key-here"  # 在此填入你的 OpenAI API 密钥
  model: "gpt-4"  # 可选: gpt-4, gpt-4-turbo, gpt-3.5-turbo
  temperature: 0.7
  max_tokens: 2000
  base_url: null  # 可选: 自定义 API 端点（如使用代理或兼容 OpenAI 的 API）

# 其他 API 配置示例（添加新 API 时在这里添加）
# claude:
#   api_key: "your-claude-key"
#   model: "claude-3-opus-20240229"
#   temperature: 0.7
#   max_tokens: 2000

# 路径限制
paths:
  home_directory: "/Users/andrew"  # 限制操作范围
  allowed_domains: []  # 浏览器操作允许的域名（空表示不限制）

# 会话设置
session:
  auto_continue: false  # 是否自动继续下一步（仍需确认）
  max_steps: 100  # 单次任务最大步数
